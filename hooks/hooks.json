{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -d \"${CLAUDE_PLUGIN_ROOT}/node_modules\" ] || npm install --prefix \"${CLAUDE_PLUGIN_ROOT}\" --silent"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/scan-tool-result.mjs"
          }
        ]
      }
    ]
  }
}
